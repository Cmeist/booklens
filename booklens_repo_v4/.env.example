# BookLens environment template
# Copy this file to .env locally and fill values there.
# Never commit real .env files, API keys, service-role keys, database URLs, or deployment credentials.

# Frontend-safe values. These may be exposed to browser code.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_API_URL=

# Server-only values. Do not expose these to browser/client-side code.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_URL=

# Optional service-to-service backend auth, if/when a backend is created.
MY_APP_API_KEY=

# Optional model provider keys, only if LLM/model calls are added later.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
LITELLM_MASTER_KEY=
