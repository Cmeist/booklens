# BookLens environment variables
# Copy this file to .env for local development.
# Never commit real .env files.

# Frontend-safe variables (safe for browser exposure in Phase 6+)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_API_URL=

# Server-only variables (seed scripts, future server tooling only)
# Do not prefix these with NEXT_PUBLIC_.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_URL=

# Optional backend/model variables
MY_APP_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
