# BookLens environment variables
# Copy this file to .env for local development.
# Never commit real .env files.

# Frontend-safe variables (safe for browser exposure in Phase 6+)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_API_URL=

# Server-only variables (seed scripts, future server tooling only)
# Do not prefix these with NEXT_PUBLIC_.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_URL=

# Required for Open Library collection (server-only)
BOOKLENS_CONTACT_EMAIL=

# Optional Google Books enrichment (server-only)
GOOGLE_BOOKS_API_KEY=

# Modal deployment uses a secret named booklens-secrets containing:
# SUPABASE_DB_URL, BOOKLENS_CONTACT_EMAIL, and optional GOOGLE_BOOKS_API_KEY.
MY_APP_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
